<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} — matupani</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  {{ content_for_header }}
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:      oklch(6% 0 0);
      --card:    oklch(10% 0 0);
      --text:    oklch(96% 0 0);
      --muted:   oklch(50% 0 0);
      --accent:  oklch(73% 0.22 145);
      --border:  oklch(17% 0 0);
      --border2: oklch(26% 0 0);
    }
    body { background: var(--bg); color: var(--text); font-family: 'DM Sans', system-ui, sans-serif; line-height: 1.6; min-height: 100vh; }
    a { color: inherit; text-decoration: none; }
  </style>
</head>
<body>
  {{ content_for_layout }}
</body>
</html>
